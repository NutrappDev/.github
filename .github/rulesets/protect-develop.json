{
  "_comment": "Protección de la rama develop. Aplicar con: scripts/apply-rulesets.sh",

  "name": "Protect develop",
  "target": "branch",
  "enforcement": "active",

  "conditions": {
    "ref_name": {
      "include": ["refs/heads/develop"],
      "exclude": []
    },
    "repository_name": {
      "include": ["~ALL"],
      "exclude": [".github"],
      "protected": false
    }
  },

  "bypass_actors": [
    {
      "actor_id": null,
      "actor_type": "OrganizationAdmin",
      "bypass_mode": "always"
    }
  ],

  "rules": [
    {
      "_comment": "Bloquear pushes directos — toda integración debe ser via PR. Squash merge obligatorio para mantener historial limpio en develop (1 commit por PR).",
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": ["squash"]
      }
    },
    {
      "_comment": "Historial lineal — fuerza squash o rebase, impide merge commits en develop",
      "type": "required_linear_history"
    },
    {
      "_comment": "Dispara org-pr-checks.yml desde NutrappDev/.github via rulesets. No requiere pr-checks.yml en el repo.",
      "type": "workflows",
      "parameters": {
        "workflows": [
          {
            "path": ".github/workflows/org-pr-checks.yml",
            "repository_id": 1164892300,
            "ref": "main"
          }
        ]
      }
    },
    {
      "_comment": "Bloquear force push",
      "type": "non_fast_forward"
    },
    {
      "_comment": "Bloquear eliminación de la rama",
      "type": "deletion"
    }
  ]
}
