{
  "_comment": "Protección de la rama qa. Aplicar con: scripts/apply-rulesets.sh",

  "name": "Protect qa",
  "target": "branch",
  "enforcement": "active",

  "conditions": {
    "ref_name": {
      "include": ["refs/heads/qa"],
      "exclude": []
    },
    "repository_name": {
      "include": ["~ALL"],
      "exclude": [".github"],
      "protected": false
    }
  },

  "bypass_actors": [
    {
      "actor_id": null,
      "actor_type": "OrganizationAdmin",
      "bypass_mode": "always"
    }
  ],

  "rules": [
    {
      "_comment": "Solo PRs — fuente válida: release/qa-YYYY-MM-DD (validado por pr-validation.yml). Rebase merge obligatorio para mantener historial lineal y trazabilidad de cherry-picks.",
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": ["rebase"]
      }
    },
    {
      "_comment": "SIN required_linear_history — qa debe recibir merge commits para preservar trazabilidad de cherry-picks",
      "_comment2": "Dispara org-pr-checks.yml desde NutrappDev/.github via rulesets. No requiere pr-checks.yml en el repo.",
      "type": "workflows",
      "parameters": {
        "workflows": [
          {
            "path": ".github/workflows/org-pr-checks.yml",
            "repository_id": 1164892300,
            "ref": "main"
          }
        ]
      }
    },
    {
      "_comment": "Bloquear force push",
      "type": "non_fast_forward"
    },
    {
      "_comment": "Bloquear eliminación de la rama",
      "type": "deletion"
    }
  ]
}
